{
  "name": "@magic-apps-cloud/sdk",
  "version": "0.1.0",
  "description": "Magic Apps Cloud SDK for TypeScript/JavaScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": ["magicapps", "sdk", "api", "backend", "serverless", "paas"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/magicapps/magicapps-infra.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://github.com/magicapps/magicapps-infra/tree/main/sdks/typescript#readme",
  "bugs": {
    "url": "https://github.com/magicapps/magicapps-infra/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typedoc": "^0.26.0",
    "typescript": "~5.9.3",
    "vitest": "^1.6.1"
  }
}
