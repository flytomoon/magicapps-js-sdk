{
  "name": "@magicapps/sdk",
  "version": "0.1.0",
  "description": "MagicApps Developer SDK for TypeScript/JavaScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["magicapps", "sdk", "api"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^1.6.1"
  }
}
